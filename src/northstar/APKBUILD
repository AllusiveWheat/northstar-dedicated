# Maintainer: pg9182 <96569817+pg9182@users.noreply.github.com>
pkgname=northstar
pkgver=1.31.6.7
pkgver_tf=2.0.11.0
pkgver_ns="${pkgver%.*}"
pkgrel=0
pkgdesc="Northstar binaries and mods"
pkgver_ion="${pkgver##*.}"

url="https://github.com/R2Ion/Ion"
license="MIT"

arch="x86_64"
source="https://github.com/R2Ion/Ion/releases/download/v${pkgver_ns}_${pkgver_ion}/Ion.release.v${pkgver_ns}.zip"

check() {
	ls "$srcdir"
	test -f "$srcdir/NorthstarLauncher.exe"
	test -f "$srcdir/R2Northstar/mods/Northstar.CustomServers/mod/cfg/autoexec_ns_dedicatedserver.cfg"
	test -d "$srcdir/R2Northstar/mods/Northstar.CustomServers/mod/maps/graphs"
	test -d "$srcdir/R2Northstar/mods/Northstar.CustomServers/mod/maps/navmesh"
	test -f "$srcdir/bin/x64_dedi/d3d11.dll"
}

package() {
	rm "$srcdir"/*.zip
	mkdir -p "$pkgdir/usr/lib/northstar"
	cp -r "$srcdir/." "$pkgdir/usr/lib/northstar/"
}
sha512sums="
  4fd16e4d5b77f14d39ec1ad1e74629fd9d79ec162be5b43b1076b114b418ea50ee71d1bd93a75a5f2e56782ed6d3ecebbb2e1bfaba173970c69d439da6bd89c9 Ion.release.v$pkgver_ns.zip
"
